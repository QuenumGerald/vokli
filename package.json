{
  "name": "volkli-sdk",
  "version": "1.0.1",
  "private": false,
  "type": "module",
  "workspaces": [
    "packages/*",
    "examples/*"
  ],
  "files": [
    "README.md",
    "CHANGELOG.md",
    "packages/core/dist",
    "packages/knowledge/dist",
    "packages/sdk/dist",
    "packages/testing/dist",
    "packages/vapi/dist"
  ],
  "main": "./packages/sdk/dist/index.js",
  "types": "./packages/sdk/dist/index.d.ts",
  "bin": {
    "vokli": "./packages/sdk/dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./packages/sdk/dist/index.d.ts",
      "import": "./packages/sdk/dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc --build --force && chmod +x packages/sdk/dist/cli.js",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "test": "vitest run",
    "typecheck": "tsc --build"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.5",
    "@types/node": "^22.15.3",
    "eslint": "^9.25.1",
    "prettier": "^3.5.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.31.0",
    "vitest": "^3.1.2"
  }
}
